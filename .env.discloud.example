# ════════════════════════════════════════════════════════════════════════════
# Paperclip — Variáveis de Ambiente para Discloud
# Configure cada valor em: Discloud Painel → App → Environment Variables
# NÃO commite este arquivo com valores reais
# ════════════════════════════════════════════════════════════════════════════

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
SERVE_UI=true
NODE_ENV=production

# ─── Banco de Dados (Neon — conexão direta, porta 5432) ──────────────────────
DATABASE_URL=postgresql://USER:PASS@ep-XXXX.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# ─── Autenticação (Better Auth) ──────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=CHAVE_SECRETA_BASE64

# ─── URL Pública do Discloud ─────────────────────────────────────────────────
PAPERCLIP_PUBLIC_URL=https://paperclip.discloudapp.com

# ─── Modo de Deployment ──────────────────────────────────────────────────────
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public

# ─── Google Vertex AI — Credenciais (JSON em uma linha) ──────────────────────
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── Google Vertex AI — Projeto e Região ─────────────────────────────────────
GOOGLE_CLOUD_PROJECT=seu-projeto-gcp
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Instância Paperclip ─────────────────────────────────────────────────────
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
